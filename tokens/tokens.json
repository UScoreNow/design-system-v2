{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "AtomSN — tema editorial AtomSN. Fuente única de verdad. Base = crema apapelada + tinta cálida; acentos = verde césped + negro tinta. Prohibido #FFFFFF y #000000 puros; ink.900 (#0E0D0A) es el negro legal más oscuro.",
  "$meta": {
    "name": "AtomSN Design System",
    "version": "2.0.0",
    "theme": "atomsn",
    "platform": "Flutter (mobile-first + web)",
    "modes": ["light", "dark"],
    "rules": {
      "forbidden": ["#FFFFFF", "#000000"],
      "darkestLegalInk": "{color.ink.900}",
      "lightestLegalPaper": "{color.paper.50}",
      "accentScarcity": "El verde es escaso: solo acciones, estados activos/seleccionados y deltas positivos.",
      "fillVsText": "Los tokens *.500 (green/yellow/red) son de RELLENO/ICONO; sus *.700 son los de TEXTO sobre papel (AA+)."
    }
  },

  "color": {
    "paper": {
      "$type": "color",
      "$description": "Rampa neutra crema cálida. Sustituye a la gris fría del sistema anterior.",
      "50":  { "$value": "#FBF8F0", "$description": "papel más claro; fondo app (light)" },
      "100": { "$value": "#F5F0E3", "$description": "superficie elevada / cards; texto primario (dark)" },
      "200": { "$value": "#ECE4D2", "$description": "superficie con tinte, hover, raised" },
      "300": { "$value": "#DCD2BC", "$description": "bordes y reglas hairline (light)" },
      "400": { "$value": "#C2B69D", "$description": "borde fuerte / relleno disabled / líderes punteados" },
      "500": { "$value": "#A6987C", "$description": "texto tenue (dark) / mid neutro" },
      "600": { "$value": "#857862", "$description": "texto terciario (light)" },
      "700": { "$value": "#615847", "$description": "texto secundario (light) / borde (dark)" },
      "800": { "$value": "#403A30", "$description": "superficie elevada cálida (dark raised)" },
      "900": { "$value": "#2B2820", "$description": "neutro cálido más oscuro" }
    },
    "ink": {
      "$type": "color",
      "$description": "Negro tinta cálido (lleva un susurro del tono papel para no enfriar sobre crema).",
      "50":  { "$value": "#6E6A60", "$description": "tinta tenue / captions" },
      "100": { "$value": "#514D44", "$description": "tinta media-tenue" },
      "300": { "$value": "#39362E", "$description": "superficie base (dark surface) / regla de sección" },
      "500": { "$value": "#26241E", "$description": "tinta estándar / regla de sección bajo masthead" },
      "700": { "$value": "#1A1814", "$description": "tinta de titular / texto primario (light)" },
      "900": { "$value": "#0E0D0A", "$description": "NEGRO tinta: destacados, sellos 'FINAL', masthead. Negro legal más oscuro." },
      "bg":  { "$value": "#16140F", "$description": "fondo base del tema oscuro 'AtomSN Dark'" }
    },
    "green": {
      "$type": "color",
      "$description": "Verde césped cálido. Acento único de interacción. Escaso.",
      "50":  { "$value": "#EAF1E4", "$description": "superficie verde sutil (action.subtle light)" },
      "100": { "$value": "#CDDFC0" },
      "200": { "$value": "#AECF96", "$description": "active (dark)" },
      "300": { "$value": "#8FBE6F", "$description": "acción primaria / hover (dark)" },
      "400": { "$value": "#5FA453" },
      "500": { "$value": "#3E8E45", "$description": "acento primario (light): acción, activo, marca" },
      "600": { "$value": "#327237", "$description": "hover de acción (light)" },
      "700": { "$value": "#27592C", "$description": "VERDE para texto/enlaces sobre papel (AA)" },
      "800": { "$value": "#1D4421" },
      "900": { "$value": "#163518", "$description": "verde profundo" }
    },
    "yellow": {
      "$type": "color",
      "$description": "Mostaza editorial. Doble función: highlight 'marcador' editorial + tarjeta amarilla/advertencia.",
      "50":  { "$value": "#FBF4D8" },
      "100": { "$value": "#F6E8BE", "$description": "wash de highlight 'marker' (highlight.mark)" },
      "200": { "$value": "#F0D89B" },
      "300": { "$value": "#E8C863", "$description": "acentos de kicker / advertencia (dark)" },
      "400": { "$value": "#DFB740" },
      "500": { "$value": "#D6A52E", "$description": "tarjeta amarilla / warning (light)" },
      "600": { "$value": "#B98A1F" },
      "700": { "$value": "#9A7416", "$description": "AMARILLO para texto sobre papel (AA)" },
      "800": { "$value": "#7A5B13" },
      "900": { "$value": "#5C4410" }
    },
    "red": {
      "$type": "color",
      "$description": "Ladrillo cálido de tinta. En vivo / error / estado crítico.",
      "50":  { "$value": "#F7E6E4" },
      "100": { "$value": "#EFC9C6" },
      "200": { "$value": "#E29E99" },
      "300": { "$value": "#D5736C" },
      "400": { "$value": "#CC554D", "$description": "live/error (dark)" },
      "500": { "$value": "#C5403A", "$description": "live/error (light): dot pulsante, alertas" },
      "600": { "$value": "#A8332E" },
      "700": { "$value": "#8C2A26", "$description": "ROJO para texto sobre papel (AA)" },
      "800": { "$value": "#6E211E" },
      "900": { "$value": "#511817" }
    },
    "indigo": {
      "$type": "color",
      "$description": "Información neutral / estadísticas complementarias. Se mantiene del sistema anterior; uso escaso y solo para status.info.",
      "50":  { "$value": "#EEF2FF" },
      "100": { "$value": "#E0E7FF" },
      "200": { "$value": "#C7D2FE" },
      "300": { "$value": "#A5B4FC" },
      "400": { "$value": "#818CF8", "$description": "info (dark)" },
      "500": { "$value": "#6366F1", "$description": "info (light)" },
      "600": { "$value": "#4F46E5" },
      "700": { "$value": "#4338CA", "$description": "info para texto sobre papel" },
      "800": { "$value": "#3730A3" },
      "900": { "$value": "#312E81" }
    }
  },

  "semantic": {
    "$description": "Capa de uso en producto. Los componentes consumen SOLO estos tokens. Cada modo resuelve a un token base.",
    "light": {
      "$description": "Tema 'AtomSN Light': fondo crema + tinta + acentos verde/negro.",
      "bg": {
        "$type": "color",
        "base":    { "$value": "{color.paper.50}" },
        "surface": { "$value": "{color.paper.100}" },
        "raised":  { "$value": "{color.paper.200}" },
        "subtle":  { "$value": "{color.paper.100}" },
        "overlay": { "$value": "{color.ink.900}", "$description": "usar con opacidad 0.5" },
        "inverse": { "$value": "{color.ink.900}" }
      },
      "text": {
        "$type": "color",
        "primary":    { "$value": "{color.ink.700}" },
        "secondary":  { "$value": "{color.paper.700}" },
        "tertiary":   { "$value": "{color.paper.600}" },
        "muted":      { "$value": "{color.paper.500}" },
        "disabled":   { "$value": "{color.paper.400}" },
        "inverse":    { "$value": "{color.paper.50}" },
        "onPrimary":  { "$value": "{color.paper.50}", "$description": "texto sobre relleno verde; usar peso bold ≥14px" },
        "link":       { "$value": "{color.green.700}" }
      },
      "action": {
        "$type": "color",
        "primary":  { "$value": "{color.green.500}" },
        "hover":    { "$value": "{color.green.600}" },
        "active":   { "$value": "{color.green.700}" },
        "disabled": { "$value": "{color.paper.300}" },
        "subtle":   { "$value": "{color.green.50}" }
      },
      "accent": {
        "$type": "color",
        "ink": { "$value": "{color.ink.900}", "$description": "destacados/sellos en negro tinta" }
      },
      "border": {
        "$type": "color",
        "default":  { "$value": "{color.paper.300}" },
        "subtle":   { "$value": "{color.paper.200}" },
        "strong":   { "$value": "{color.paper.400}" },
        "active":   { "$value": "{color.green.500}" },
        "hairline": { "$value": "{color.paper.300}", "$description": "regla fina editorial 1px" },
        "section":  { "$value": "{color.ink.500}", "$description": "regla de sección 2px bajo masthead" }
      },
      "status": {
        "$type": "color",
        "live":        { "$value": "{color.red.500}" },
        "liveText":    { "$value": "{color.red.700}" },
        "error":       { "$value": "{color.red.500}" },
        "errorText":   { "$value": "{color.red.700}" },
        "success":     { "$value": "{color.green.500}" },
        "successText": { "$value": "{color.green.700}" },
        "warning":     { "$value": "{color.yellow.500}" },
        "warningText": { "$value": "{color.yellow.800}", "$description": "yellow.800 para AA pleno en texto pequeño sobre papel" },
        "info":        { "$value": "{color.indigo.500}" },
        "infoText":    { "$value": "{color.indigo.700}" }
      },
      "highlight": {
        "$type": "color",
        "mark": { "$value": "{color.yellow.100}", "$description": "wash de marcador tras stats/records clave" }
      }
    },
    "dark": {
      "$description": "Tema 'AtomSN Dark': fondo tinta + texto crema + acentos verde/papel.",
      "bg": {
        "$type": "color",
        "base":    { "$value": "{color.ink.bg}" },
        "surface": { "$value": "{color.ink.300}" },
        "raised":  { "$value": "{color.paper.800}" },
        "subtle":  { "$value": "{color.ink.300}" },
        "overlay": { "$value": "{color.ink.900}", "$description": "usar con opacidad 0.7" },
        "inverse": { "$value": "{color.paper.50}" }
      },
      "text": {
        "$type": "color",
        "primary":    { "$value": "{color.paper.100}" },
        "secondary":  { "$value": "{color.paper.400}" },
        "tertiary":   { "$value": "{color.paper.500}" },
        "muted":      { "$value": "{color.paper.500}" },
        "disabled":   { "$value": "{color.paper.700}" },
        "inverse":    { "$value": "{color.ink.900}" },
        "onPrimary":  { "$value": "{color.ink.900}", "$description": "texto sobre verde claro (green.300): tinta oscura" },
        "link":       { "$value": "{color.green.300}" }
      },
      "action": {
        "$type": "color",
        "primary":  { "$value": "{color.green.300}" },
        "hover":    { "$value": "{color.green.200}" },
        "active":   { "$value": "{color.green.100}" },
        "disabled": { "$value": "{color.paper.700}" },
        "subtle":   { "$value": "{color.ink.300}" }
      },
      "accent": {
        "$type": "color",
        "ink": { "$value": "{color.paper.100}", "$description": "en dark, el sello de alto contraste es papel" }
      },
      "border": {
        "$type": "color",
        "default":  { "$value": "{color.paper.700}" },
        "subtle":   { "$value": "{color.ink.300}" },
        "strong":   { "$value": "{color.paper.500}" },
        "active":   { "$value": "{color.green.300}" },
        "hairline": { "$value": "{color.paper.700}" },
        "section":  { "$value": "{color.paper.400}" }
      },
      "status": {
        "$type": "color",
        "live":        { "$value": "{color.red.400}" },
        "liveText":    { "$value": "{color.red.300}", "$description": "red.300 para AA en texto sobre fondo oscuro" },
        "error":       { "$value": "{color.red.400}" },
        "errorText":   { "$value": "{color.red.300}", "$description": "red.300 para AA en texto sobre fondo oscuro" },
        "success":     { "$value": "{color.green.300}" },
        "successText": { "$value": "{color.green.300}" },
        "warning":     { "$value": "{color.yellow.300}" },
        "warningText": { "$value": "{color.yellow.300}" },
        "info":        { "$value": "{color.indigo.400}" },
        "infoText":    { "$value": "{color.indigo.400}" }
      },
      "highlight": {
        "$type": "color",
        "mark": { "$value": "{color.yellow.700}", "$description": "wash de marcador atenuado para fondo oscuro" }
      }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "serif":        { "$value": ["ElmsSans", "sans-serif"], "$description": "Alias historico de la familia de cabecera (masthead/headline/display). Ahora resuelve a ElmsSans: el sistema unifica en una unica familia." },
      "sans":         { "$value": ["ElmsSans", "sans-serif"], "$description": "Cuerpo, UI, labels, captions, stats (con cifras tabulares)." }
    },
    "size": {
      "$type": "dimension",
      "sm":  { "$value": "12px" },
      "md":  { "$value": "14px" },
      "lg":  { "$value": "16px" },
      "xl":  { "$value": "18px" },
      "2xl": { "$value": "20px" },
      "3xl": { "$value": "24px" },
      "4xl": { "$value": "32px" },
      "5xl": { "$value": "40px" },
      "6xl": { "$value": "48px" },
      "7xl": { "$value": "60px" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":   { "$value": 400 },
      "medium":    { "$value": 500 },
      "semibold":  { "$value": 600 },
      "bold":      { "$value": 700 },
      "extrabold": { "$value": 800 },
      "black":     { "$value": 900 }
    },
    "lineHeight": {
      "$type": "number",
      "tight":   { "$value": 1.1 },
      "snug":    { "$value": 1.25 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.65 }
    },
    "tracking": {
      "$type": "dimension",
      "tight":  { "$value": "-0.02em" },
      "normal": { "$value": "0em" },
      "wide":   { "$value": "0.02em" },
      "xwide":  { "$value": "0.06em" },
      "kicker": { "$value": "0.08em", "$description": "overline/kicker en mayúsculas" }
    }
  },

  "text": {
    "$description": "Composiciones semánticas. Familia única ElmsSans (el alias 'serif' resuelve a ElmsSans w400 en masthead/headline). stats con cifras tabulares.",
    "masthead": {
      "xl": { "family": "{font.family.serif}", "size": "{font.size.6xl}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.tight}", "tracking": "{font.tracking.tight}", "$description": "nameplate de pantalla/sección" },
      "lg": { "family": "{font.family.serif}", "size": "{font.size.4xl}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.snug}", "tracking": "{font.tracking.tight}" }
    },
    "headline": {
      "xl": { "family": "{font.family.serif}", "size": "{font.size.4xl}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.snug}", "tracking": "{font.tracking.normal}", "$description": "titular editorial/crónica" },
      "lg": { "family": "{font.family.serif}", "size": "{font.size.3xl}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.snug}", "tracking": "{font.tracking.normal}" }
    },
    "display": {
      "score": { "family": "{font.family.sans}", "size": "{font.size.7xl}", "weight": "{font.weight.extrabold}", "lineHeight": "{font.lineHeight.tight}", "tracking": "{font.tracking.tight}", "tabular": true, "$description": "marcador principal de partido" },
      "stat":  { "family": "{font.family.sans}", "size": "{font.size.5xl}", "weight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}", "tracking": "{font.tracking.tight}", "tabular": true }
    },
    "title": {
      "lg": { "family": "{font.family.sans}", "size": "{font.size.2xl}", "weight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.snug}", "tracking": "{font.tracking.normal}", "$description": "título de card / dato (UI permanece sans)" },
      "md": { "family": "{font.family.sans}", "size": "{font.size.xl}", "weight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.normal}", "tracking": "{font.tracking.normal}" }
    },
    "body": {
      "lg": { "family": "{font.family.sans}", "size": "{font.size.lg}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}" },
      "md": { "family": "{font.family.sans}", "size": "{font.size.md}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}", "$description": "el más frecuente" },
      "sm": { "family": "{font.family.sans}", "size": "{font.size.sm}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}" }
    },
    "label": {
      "lg": { "family": "{font.family.sans}", "size": "{font.size.md}", "weight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.tight}" },
      "md": { "family": "{font.family.sans}", "size": "{font.size.sm}", "weight": "{font.weight.medium}", "lineHeight": "{font.lineHeight.tight}" }
    },
    "overline": { "family": "{font.family.sans}", "size": "{font.size.sm}", "weight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.tight}", "tracking": "{font.tracking.kicker}", "transform": "uppercase", "$description": "kicker editorial: 'GRUPO A', 'EN VIVO', 'JORNADA 12'" },
    "stat": {
      "lg": { "family": "{font.family.sans}", "size": "{font.size.3xl}", "weight": "{font.weight.bold}", "lineHeight": "{font.lineHeight.tight}", "tracking": "{font.tracking.tight}", "tabular": true },
      "md": { "family": "{font.family.sans}", "size": "{font.size.xl}", "weight": "{font.weight.semibold}", "lineHeight": "{font.lineHeight.tight}", "tabular": true }
    },
    "caption": { "family": "{font.family.sans}", "size": "{font.size.sm}", "weight": "{font.weight.regular}", "lineHeight": "{font.lineHeight.normal}" }
  },

  "space": {
    "$type": "dimension",
    "$description": "Escala base 4px.",
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" }
  },

  "radius": {
    "$type": "dimension",
    "$description": "Editorial: radios contenidos; el periódico prefiere esquinas rectas/leves. radius.md sigue siendo el estándar de cards.",
    "none": { "$value": "0px", "$description": "reglas, sellos, tablas: borde recto editorial" },
    "xs":   { "$value": "4px" },
    "sm":   { "$value": "8px" },
    "md":   { "$value": "12px" },
    "lg":   { "$value": "16px" },
    "xl":   { "$value": "24px" },
    "2xl":  { "$value": "32px" },
    "full": { "$value": "9999px", "$description": "avatares, dots, badges, pills" }
  },

  "border": {
    "$type": "dimension",
    "$description": "Grosores de regla editorial.",
    "hairline": { "$value": "1px" },
    "section":  { "$value": "2px" }
  }
}
